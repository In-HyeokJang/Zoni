# ============================================================
# application-local.yml 설정 예시
# 이 파일을 복사해서 application-local.yml 로 만들고
# 실제 값으로 채워서 사용하세요.
# application-local.yml 은 .gitignore 에 등록되어 있어 커밋되지 않습니다.
# ============================================================

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/zoni_user?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password: YOUR_MYSQL_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  data:
    redis:
      host: localhost
      port: 6379

jwt:
  secret: zoni-super-secret-key-must-be-at-least-32-characters-long!
  access-token-expire: 1800000    # 30분 (ms)
  refresh-token-expire: 604800000 # 7일 (ms)

# 카카오 OAuth 설정
# 카카오 개발자 콘솔 (https://developers.kakao.com) 에서 앱 생성 후 발급
# [내 애플리케이션] → [앱 키] → REST API 키 복사
# [내 애플리케이션] → [카카오 로그인] → [Redirect URI] 등록
kakao:
  rest-api-key: YOUR_KAKAO_REST_API_KEY
  redirect-uri: http://localhost:8081/api/users/login/kakao/callback
  client-secret: YOUR_KAKAO_CLIENT_SECRET  # 카카오 콘솔 → [보안] → Client Secret (선택사항이지만 등록 시 필수)
