POST http://localhost:8081/api/users/logout
Authorization: Bearer eyJhbGciOiJIUzM4NCJ9.eyJzdWIiOiJ0YXNzQHpvbmkuY29tIiwidXNlcklkIjozLCJpYXQiOjE3NzUyNzE5NDQsImV4cCI6MTc3NTI3Mzc0NH0.QI3a8Y3PTabE4IE0pJVUhvxXwq86NiD297_YJf5EoSxgJs6dgBh5WCqK14o58ppt

